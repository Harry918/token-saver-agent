# Copy this file to .env.docker, replace every path, then run:
# docker compose --env-file .env.docker up -d --build
#
# DOCKER_SOCKET_PATH is only needed with compose.docker-control.yaml, which lets the
# Telegram bridge deploy generated backend containers on your Docker host.

PROJECTS_ROOT=/absolute/path/to/projects
TOKEN_SAVER_CONFIG_FILE=/absolute/path/to/config.toml
TOKEN_SAVER_STATE_DIR=/absolute/path/to/state-directory
TELEGRAM_TOKEN_FILE=/absolute/path/to/telegram-token
CODEX_HOME_DIR=/absolute/path/to/.codex
DOCKER_SOCKET_PATH=/var/run/docker.sock
HOST_UID=1000
HOST_GID=1000
